{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "environment": {
        "QTFRAMEWORK_BYPASS_LICENSE_CHECK": "1"
      }
    },
    {
      "name": "default",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "environment": {
        "QTFRAMEWORK_BYPASS_LICENSE_CHECK": "1"
      }
    }
  ]
}
