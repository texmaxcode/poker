# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://texasholdemgym.com

# ── Admin panel (/admin) ─────────────────────────────────────────────────────
# Long random string used to sign admin session cookies (min 16 chars)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string
# Password for /admin login
ADMIN_PASSWORD=change-me

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/texasholdemgym

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: https://dashboard.stripe.com/webhooks
# Listen to: checkout.session.completed

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@texasholdemgym.com
SUPPORT_EMAIL=support@texasholdemgym.com

# ── AWS / Downloads ───────────────────────────────────────────────────────────
# CloudFront or S3 base URL (no trailing slash)
NEXT_PUBLIC_DOWNLOAD_BASE_URL=https://d1234abcd.cloudfront.net
# S3 bucket: /downloads/texas-holdem-gym-windows.exe
#             /downloads/texas-holdem-gym-mac.dmg
